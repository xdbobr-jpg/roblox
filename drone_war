-- Проверка: является ли объект валидным дроном из списка
local function isTargetDrone(object)
	if object:IsA("Model") and object.Name then
		return TargetDronesList[string.lower(object.Name)] ~= nil
	end
	return false
end

-- Безопасное получение цвета команды игрока
local function getPlayerColor(player)
	if player.Team and player.TeamColor then
		return player.TeamColor.Color
	end
	return Color3.fromRGB(255, 255, 255)
end

-- Поиск сиденья внутри модели дрона
local function getDroneSeat(droneModel)
	return droneModel:FindFirstChildOfClass("VehicleSeat") or droneModel:FindFirstChild("VehicleSeat", true)
end

-- Поиск фюзеляжа (основной детали) дрона для точного наведения
local function getValidDronePart(droneModel)
	if droneModel.PrimaryPart and not droneModel.PrimaryPart:IsA("VehicleSeat") then
		return droneModel.PrimaryPart
	end
	local bodyNames = {"base", "main", "body", "chassis", "hull", "part"}
	for _, name in ipairs(bodyNames) do
		local found = droneModel:FindFirstChild(name, true)
		if found and found:IsA("BasePart") and not found:IsA("VehicleSeat") then
			return found
		end
	end
	for _, child in ipairs(droneModel:GetDescendants()) do
		if child:IsA("BasePart") and not child:IsA("VehicleSeat") then
			return child
		end
	end
	return nil
end

-- Определение пилота, сидящего в дроне
local function getDronePilot(droneModel)
	local seat = getDroneSeat(droneModel)
	if seat and seat.Occupant then
		local char = seat.Occupant.Parent
		if char then
			return Players:GetPlayerFromCharacter(char)
		end
	end
	return nil
end

-- Трассировка лучей для проверки видимости цели (Wall Check)
local function isTargetVisible(targetPart)
	local origin = Camera.CFrame.Position
	local direction = targetPart.Position - origin
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
	
	local result = Workspace:Raycast(origin, direction, raycastParams)
	return result == nil
end

-- Алгоритм поиска ближайшей к курсору цели по заданным критериям
local function getClosestAimTarget()
	local closestTargetPart = nil
	local shortestDistance = Cheats_Settings.FovRadius
	local mousePos = UserInputService:GetMouseLocation()
	
	-- Проверка игроков
	if Cheats_Settings.TargetPlayers then
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				local isAllowed = not Cheats_Settings.TeamCheck or (player.Team ~= LocalPlayer.Team)
				
				if isAllowed then
					local targetPart = player.Character:FindFirstChild(Cheats_Settings.AimTarget)
					local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
					
					if targetPart and humanoid and humanoid.Health > 0 then
						local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
						if onScreen then
							local distanceToMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
							if distanceToMouse < shortestDistance then
								if not Cheats_Settings.WallCheck or isTargetVisible(targetPart) then
									shortestDistance = distanceToMouse
									closestTargetPart = targetPart
								end
							end
						end
					end
				end
			end
		end
	end
	
	-- Проверка дронов
	if Cheats_Settings.TargetDrones then
		for _, obj in ipairs(Workspace:GetChildren()) do
			if isTargetDrone(obj) then
				local dronePart = getValidDronePart(obj)
				if dronePart then
					local screenPos, onScreen = Camera:WorldToScreenPoint(dronePart.Position)
					if onScreen then
						local distanceToMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
						if distanceToMouse < shortestDistance then
							if not Cheats_Settings.WallCheck or isTargetVisible(dronePart) then
								shortestDistance = distanceToMouse
								closestTargetPart = dronePart
							end
						end
					end
				end
			end
		end
	end
	
	return closestTargetPart
end

-- Бесконечный цикл аимбота, привязанный к тикам рендера камеры
RunService.RenderStepped:Connect(function()
	if not Cheats_Settings.AimEnabled then return end
	
	local target = getClosestAimTarget()
	if target then
		if Cheats_Settings.AimMethod == "Camera (CFrame)" then
			local currentCFrame = Camera.CFrame
			local targetCFrame = CFrame.new(currentCFrame.Position, target.Position)
			Camera.CFrame = currentCFrame:Lerp(targetCFrame, 1 / Cheats_Settings.AimSmoothness)
		elseif Cheats_Settings.AimMethod == "Mouse (mousemoverel)" and mousemove then
			local screenPos, onScreen = Camera:WorldToScreenPoint(target.Position)
			if onScreen then
				local mousePos = UserInputService:GetMouseLocation()
				local moveX = (screenPos.X - mousePos.X) / Cheats_Settings.AimSmoothness
				local moveY = (screenPos.Y - mousePos.Y) / Cheats_Settings.AimSmoothness
				mousemove(math.round(moveX), math.round(moveY))
			end
		end
	end
end)

